# ─── LLM 后端（优先级：Step > Anthropic > mock）────────
# 全部留空则走 mock 内置样例（零配置可跑通全流程）

# 【Step 阶跃星辰，OpenAI 兼容】https://platform.stepfun.com/
STEP_API_KEY=
STEP_MODEL=step-3.7-flash
# STEP_BASE_URL=https://api.stepfun.com/v1

# Step 语音能力（可选；默认值即当前实现使用的模型）
# STEP_TTS_MODEL=step-tts-mini
# STEP_TTS_VOICE=cixingnansheng
# STEP_ASR_MODEL=stepaudio-2.5-asr
# STEP_AUDIO_TIMEOUT_MS=60000
# STEP_TTS_TIMEOUT_MS=25000
# STEP_TTS_MAX_CHARS=180

# 【Anthropic Claude】（可选）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# 单次 LLM 调用超时（毫秒，可选，默认 40000）
# LLM_TIMEOUT_MS=40000

# ─── Auth ────────────────────────────────────────────
# 会话 cookie 的 HMAC 签名密钥。生产环境务必设置为随机长字符串。
# 本地开发不设也能跑（用内置弱密钥），但切勿用于生产。
AUTH_SECRET=

# ─── Database ────────────────────────────────────────
# 本地优先：默认 SQLite。生产可换成 Supabase Postgres：
# DATABASE_URL=postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"
